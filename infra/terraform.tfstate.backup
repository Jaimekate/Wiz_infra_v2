          "index_key": 0,
          "schema_version": 0,
          "attributes": {
            "id": "976786747",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Effect\": \"Allow\",\n      \"Action\": \"sts:AssumeRoleWithWebIdentity\",\n      \"Principal\": {\n        \"Federated\": \"arn:aws:iam::565393060528:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/C1BB0DD5B46481DA8023F125BD22E80D\"\n      },\n      \"Condition\": {\n        \"StringEquals\": {\n          \"oidc.eks.us-east-1.amazonaws.com/id/C1BB0DD5B46481DA8023F125BD22E80D:aud\": \"sts.amazonaws.com\",\n          \"oidc.eks.us-east-1.amazonaws.com/id/C1BB0DD5B46481DA8023F125BD22E80D:sub\": \"system:serviceaccount:kube-system:aws-load-balancer-controller\"\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":\"sts:AssumeRoleWithWebIdentity\",\"Principal\":{\"Federated\":\"arn:aws:iam::565393060528:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/C1BB0DD5B46481DA8023F125BD22E80D\"},\"Condition\":{\"StringEquals\":{\"oidc.eks.us-east-1.amazonaws.com/id/C1BB0DD5B46481DA8023F125BD22E80D:aud\":\"sts.amazonaws.com\",\"oidc.eks.us-east-1.amazonaws.com/id/C1BB0DD5B46481DA8023F125BD22E80D:sub\":\"system:serviceaccount:kube-system:aws-load-balancer-controller\"}}}]}",
            "override_json": null,
            "override_policy_documents": null,
            "policy_id": null,
            "source_json": null,
            "source_policy_documents": null,
            "statement": [
              {
                "actions": [
                  "sts:AssumeRoleWithWebIdentity"
                ],
                "condition": [
                  {
                    "test": "StringEquals",
                    "values": [
                      "sts.amazonaws.com"
                    ],
